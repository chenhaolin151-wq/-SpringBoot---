# 编译后的文件 (最占用空间且不需要上传)
target/
*.class

# 运行日志
*.log

# Maven 相关
.mvn/
mvnw
mvnw.cmd

# 开发工具 (IDE) 相关配置
.idea/
*.iml
.classpath
.project
.settings/
.vscode/

# 操作系统临时文件
.DS_Store
Thumbs.db

# 依赖包 (前端最占空间、绝对不传的文件)
node_modules/
.pnpm-store/

# 编译产物 (打包后的文件)
dist/
build/

# 环境变量 (可能包含敏感 API 地址或 Key)
.env.local
.env.development.local
.env.test.local
.env.production.local

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 编辑器相关 (如果之前没加的话)
.vscode/
.idea/
